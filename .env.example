# Railway Postgres (or any Postgres)
# In Railway: Project → + New → Database → PostgreSQL → Variables → DATABASE_URL / DATABASE_PUBLIC_URL
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/railway?sslmode=require"

# Admin dashboard password
ADMIN_PASSWORD="changeme"

# Square payments (sandbox first)
# Dashboard: https://developer.squareup.com/apps → Credentials + Locations
SQUARE_ACCESS_TOKEN="sandbox-sq0idb-..."
NEXT_PUBLIC_SQUARE_APPLICATION_ID="sandbox-sq0idb-..."
NEXT_PUBLIC_SQUARE_LOCATION_ID="L..."
# sandbox | production
SQUARE_ENVIRONMENT="sandbox"

# Bank transfer invoice details (shown to customers)
BANK_NAME="Your Bank"
BANK_ACCOUNT_NAME="Travel Agency Pty Ltd"
BANK_BSB="062-000"
BANK_ACCOUNT_NUMBER="12345678"
